{
  "commentsLint": {
    "excludeFiles": ["next-env.d.ts"]
  },
  "deadCode": {
    "ignorePatterns": {
      "src": [
        "\\.test\\.",
        "__tests__/",
        "__mocks__/",
        "src/middleware.ts",
        "constants/serviceDetails"
      ],
      "tests": ["src/"],
      "common": [
        "^\\.next/",
        "\\.d\\.ts$",
        "/store/",
        "default",
        "layout\\.tsx",
        "page\\.tsx",
        "manifest\\.tsx",
        "robots\\.tsx",
        "index\\.ts$"
      ]
    }
  },
  "dumpFiles": {
    "files": [
      "src/services/fetch/services/fetchSigningData.tsx",
      "src/utils/rest/requestHelper.tsx"
    ],
    "folders": ["src/utils/rest"],
    "excludeFolders": ["node_modules", ".git"]
  }
}
